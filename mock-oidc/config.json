{
  "interactiveLogin": false,
  "httpServer": "NettyWrapper",
  "tokenCallbacks": [
    {
      "issuerId": "azure-mock",
      "tokenExpiry": 120,
      "requestMappings": [
        {
          "requestParam": "grant_type",
          "match": "authorization_code",
          "claims": {
            "sub": "subByScope",
            "sid": "1234",
            "aud": "historisk-tidsbegrenset-uforestonad",
            "groups": ["gruppe-admin"],
            "roles": ["test_oppdatert", "test_ingen_timestamp"]
          }
        },
        {
          "requestParam": "scope",
          "match": "historisk-tidsbegrenset-uforestonad/.default",
          "claims": {
            "sub": "subByScope",
            "sid": "1234",
            "aud": "historisk-tidsbegrenset-uforestonad"
          }
        }
      ]
    }
  ]
}